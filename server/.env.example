# Ro-DeepVoice — configurare gateway
# ===================================
# NOTA: acest fisier e doar un model. Copiaza-l ca `server/.env` si completeaza-l.
#
# Pentru rularea LOCALA cu Docker (imaginile de pe GitHub) NU e nevoie de nimic
# de aici — gateway-ul din container ruleaza cu LOCAL_MODE=1 si nu foloseste SSH.
#
# Sectiunea SSH e necesara DOAR pentru modul clasic client→cluster (tunel SSH).

# --- SSH catre clusterul GPU (doar pentru modul cluster) ---
SSH_HOST=<adresa-clusterului>
SSH_PORT=22
SSH_USERNAME=<utilizator>
SSH_KEY_PATH=~/.ssh/id_ed25519
SSH_PASSWORD=

# --- Gateway local ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
